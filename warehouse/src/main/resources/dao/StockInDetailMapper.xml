<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.warehouse.mapper.StockInDetailMapper">
    <resultMap id="BaseResultMap" type="com.example.warehouse.pojo.StockInDetail">
        <id column="id" property="id"/>
        <result column="stock_in_id" property="stockInId"/>
        <result column="product_id" property="productId"/>
        <result column="location_id" property="locationId"/>
        <result column="quantity" property="quantity"/>
        <result column="unit_price" property="unitPrice"/>
        <result column="amount" property="amount"/>
    </resultMap>

    <select id="findByStockInId" resultMap="BaseResultMap">
        SELECT * FROM stock_in_detail WHERE stock_in_id = #{stockInId}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO stock_in_detail (stock_in_id, product_id, location_id, quantity, unit_price, amount)
        VALUES (#{stockInId}, #{productId}, #{locationId}, #{quantity}, #{unitPrice}, #{amount})
    </insert>

    <delete id="deleteByStockInId">
        DELETE FROM stock_in_detail WHERE stock_in_id = #{stockInId}
    </delete>
</mapper>
