<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================
  【SysUserMapper.xml】用户表的 SQL 语句
  ============================================================
  这个文件就是 Mapper 接口的"具体干活的人"。
  Java 接口（SysUserMapper.java）里定义了方法名，
  这里写对应的 SQL 语句。

  关联方式：mapper 标签的 namespace 要和接口的全路径一致，
  然后 select/insert/update/delete 标签的 id 要和接口的方法名一致。

  resultMap：因为数据库字段名和 Java 属性名不一样
  （比如数据库是 real_name，Java 是 realName），
  所以需要 resultMap 来"映射"它们的关系。

  <sql> 标签：把重复的 SQL 片段抽出来复用。
  比如 WHERE 条件在很多查询里都会用到，写一次就行了。
  <include> 标签：引用上面定义好的 SQL 片段。
  ============================================================
-->
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.warehouse.mapper.SysUserMapper">

    <!--
      resultMap 的作用就是把数据库字段和 Java 属性对应起来。
      column="数据库字段名"  property="Java属性名"
      比如数据库的 real_name 对应 Java 的 realName
    -->
    <resultMap id="BaseResultMap" type="com.example.warehouse.pojo.SysUser">
        <id column="id" property="id"/>
        <result column="username" property="username"/>
        <result column="password" property="password"/>
        <result column="real_name" property="realName"/>
        <result column="phone" property="phone"/>
        <result column="email" property="email"/>
        <result column="role_id" property="roleId"/>
        <result column="dept_id" property="deptId"/>
        <result column="status" property="status"/>
        <result column="cretetime" property="creteTime"/>
    </resultMap>

    <!--
      通用的 WHERE 条件片段（给分页查询和统计总数复用）
      支持多条件组合筛选：
      - username：模糊搜索（LIKE）
      - real_name：模糊搜索（LIKE）
      - role_id：精确匹配
      - status：精确匹配
      所有条件都是可选的——没传就不加这个条件。
    -->
    <sql id="whereCondition">
        <where>
            <if test="username != null and username != ''">
                AND username LIKE CONCAT('%', #{username}, '%')
            </if>
            <if test="realName != null and realName != ''">
                AND real_name LIKE CONCAT('%', #{realName}, '%')
            </if>
            <if test="roleId != null">
                AND role_id = #{roleId}
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
        </where>
    </sql>

    <!-- 根据用户名查询用户（登录时用） -->
    <select id="findByUsername" resultMap="BaseResultMap">
        SELECT * FROM sys_user WHERE username = #{username}
    </select>

    <!-- 根据ID查询用户 -->
    <select id="findById" resultMap="BaseResultMap">
        SELECT * FROM sys_user WHERE id = #{id}
    </select>

    <!--
      新增用户（注册时用）
      useGeneratedKeys="true" keyProperty="id"
      这两句的意思是：数据库自动生成ID后，把ID赋值给 user 对象的 id 属性
      status=1 启用，cretetime=NOW() 当前时间
       role_id 由参数传入：注册时 LoginServiceImpl 不传 roleId，
       默认用 COALESCE 设为 2（仓管员）；
       管理员创建用户时由 UserCreateRequest 传入具体的 roleId。
       COALESCE(expr, default) 是 MySQL 函数：如果 expr 是 null，就返回 default
    -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        <!--
          关于 status 字段：
            COALESCE(#{status, jdbcType=INTEGER}, 0)
            - 如果 Java 代码传了 status（比如管理员创建传 1），就用传的值
            - 如果没传（null），默认为 0（禁用/待审核）
            - 自助注册：status=0 → 需要管理员审核
            - 管理员创建：status=1 → 直接启用
        -->
        INSERT INTO sys_user (username, password, real_name, phone, email, role_id, status, cretetime)
        VALUES (#{username}, #{password}, #{realName}, #{phone}, #{email},
                COALESCE(#{roleId, jdbcType=INTEGER}, 2),<!--COALESCE 是 SQL 标准函数，功能是：从左到右看参数，返回第一个不是 NULL 的值。-->
                COALESCE(#{status, jdbcType=INTEGER}, 0), NOW())<!--jdbcType=INTEGER是在告诉mybatis这个参数在数据库的类型是整型，如果为空，就会有整型和字符型两种，容易报错-->
    </insert>

    <!--
      分页查询用户列表（支持多条件筛选）
      ORDER BY cretetime DESC 让最新的用户排在最前面
      LIMIT #{offset}, #{limit} 实现分页,从第几条开始查，查几条
    -->
    <select id="selectPage" resultMap="BaseResultMap">
        SELECT * FROM sys_user
        <include refid="whereCondition"/>
        ORDER BY cretetime DESC
        LIMIT #{offset}, #{limit}
    </select>

    <!--
      统计符合条件的用户总数（分页用）
      用 COUNT(*) 而非 COUNT(1)，在这个场景下性能一样
    -->
    <select id="countPage" resultType="long">
        SELECT COUNT(*) FROM sys_user
        <include refid="whereCondition"/>
    </select>

    <!--
      根据ID更新用户信息
      使用 <set> 标签 + <if> 标签实现"只更新非空字段"：
      前端传了哪些字段，就更新哪些字段；
      没传的字段保持不变，不会覆盖成 null。

      比如只传了 phone 和 email，SQL 就变成：
        UPDATE sys_user SET phone=?, email=? WHERE id=?
    -->
    <update id="updateById">
        UPDATE sys_user
        <set>
            <if test="username != null">username = #{username},</if>
            <if test="realName != null">real_name = #{realName},</if>
            <if test="phone != null">phone = #{phone},</if>
            <if test="email != null">email = #{email},</if>
            <if test="roleId != null">role_id = #{roleId},</if>
            <if test="status != null">status = #{status},</if>
        </set>
        WHERE id = #{id}
    </update>

    <!-- 根据ID删除用户 -->
    <delete id="deleteById">
        DELETE FROM sys_user WHERE id = #{id}
    </delete>

    <!-- 更新用户状态（启用/禁用） -->
    <update id="updateStatus">
        UPDATE sys_user SET status = #{status} WHERE id = #{id}
    </update>

    <!-- 重置用户密码 -->
    <update id="updatePassword">
        UPDATE sys_user SET password = #{password} WHERE id = #{id}
    </update>

    <!--
      批量删除用户
      DELETE FROM sys_user WHERE id IN (1, 2, 3)
      <foreach> 把 List<Integer> ids 拼成 "1, 2, 3" 的形式
      注意：不能用 ${}（有SQL注入风险），这里用 #{} 是安全的
    -->
    <delete id="deleteByIds">
        DELETE FROM sys_user WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <!--
      批量更新用户状态
      UPDATE sys_user SET status = ? WHERE id IN (1, 2, 3)
    -->
    <update id="updateStatusByIds">
        UPDATE sys_user SET status = #{status} WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </update>

</mapper>
