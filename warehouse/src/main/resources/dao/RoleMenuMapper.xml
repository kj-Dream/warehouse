<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================
  【RoleMenuMapper.xml】角色菜单关联表的 SQL
  ============================================================
  维护角色和菜单之间的"多对多"关系。
  修改角色权限的典型流程：
    1. DELETE FROM sys_role_menu WHERE role_id = ?  （先清空旧权限）
    2. INSERT INTO sys_role_menu VALUES (?, ?)      （插入新权限）
    3. 以上两步在 Service 层用事务包裹，保证原子性
  ============================================================
-->
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.warehouse.mapper.RoleMenuMapper">

    <resultMap id="BaseResultMap" type="com.example.warehouse.pojo.SysRoleMenu">
        <id column="id" property="id"/>
        <result column="role_id" property="roleId"/>
        <result column="menu_id" property="menuId"/>
    </resultMap>

    <!-- 查询角色拥有的所有菜单权限 -->
    <select id="findByRoleId" resultMap="BaseResultMap">
        SELECT * FROM sys_role_menu WHERE role_id = #{roleId}
    </select>

    <!-- 给角色分配一个菜单权限 -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sys_role_menu (role_id, menu_id) VALUES (#{roleId}, #{menuId})
    </insert>

    <!-- 删除角色的所有菜单权限（重新分配权限前先清空） -->
    <delete id="deleteByRoleId">
        DELETE FROM sys_role_menu WHERE role_id = #{roleId}
    </delete>

    <!-- 删除角色时移除特定菜单关联 -->
    <delete id="deleteByRoleIdAndMenuId">
        DELETE FROM sys_role_menu WHERE role_id = #{roleId} AND menu_id = #{menuId}
    </delete>

    <!-- 统计角色下关联的用户数（删除角色前检查，有用户则不能删） -->
    <select id="countUsersByRoleId" resultType="int">
        SELECT COUNT(*) FROM sys_user WHERE role_id = #{roleId}
    </select>

</mapper>
