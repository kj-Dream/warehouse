<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.warehouse.mapper.WarehouseMapper">
    <resultMap id="BaseResultMap" type="com.example.warehouse.pojo.Warehouse">
        <id column="id" property="id"/>
        <result column="warehouse_code" property="warehouseCode"/>
        <result column="warehouse_name" property="warehouseName"/>
        <result column="address" property="address"/>
        <result column="manager" property="manager"/>
        <result column="status" property="status"/>
    </resultMap>
    <select id="findAll" resultMap="BaseResultMap">
        SELECT * FROM warehouse WHERE status = 1 ORDER BY id
    </select>
    <select id="findById" resultMap="BaseResultMap">
        SELECT * FROM warehouse WHERE id = #{id}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO warehouse (warehouse_code, warehouse_name, address, manager, status)
        VALUES (#{warehouseCode}, #{warehouseName}, #{address}, #{manager}, COALESCE(#{status}, 1))
    </insert>
    <update id="updateById">
        UPDATE warehouse
        <set>
            <if test="warehouseCode != null">warehouse_code=#{warehouseCode},</if>
            <if test="warehouseName != null">warehouse_name=#{warehouseName},</if>
            <if test="address != null">address=#{address},</if>
            <if test="manager != null">manager=#{manager},</if>
            <if test="status != null">status=#{status},</if>
        </set>
        WHERE id=#{id}
    </update>
    <delete id="deleteById">DELETE FROM warehouse WHERE id=#{id}</delete>
</mapper>
